# 应用配置
APP_NAME=MoveRenovateAI
DEBUG=true

# 数据库配置（开发环境使用 SQLite）
DATABASE_URL=sqlite+aiosqlite:///./moverenovateai.db

# 生产环境使用 PostgreSQL
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/moverenovateai

# Redis 配置
REDIS_URL=redis://localhost:6379/0

# JWT 密钥（生产环境请修改）
SECRET_KEY=your-super-secret-key-change-in-production

# LLM 提供商配置（支持 openai / deepseek / qwen / anthropic）
LLM_PROVIDER=deepseek
LLM_TIMEOUT_SECONDS=90

# OpenAI 配置
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4
OPENAI_BASE_URL=https://api.openai.com/v1

# DeepSeek 配置（推荐）
DEEPSEEK_API_KEY=sk-your-deepseek-api-key
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# Qwen 配置
QWEN_API_KEY=
QWEN_MODEL=qwen-max
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# Anthropic / Claude 兼容代理配置
# 注意：不要把真实 API Key 提交到代码仓库。复制本文件为 backend/.env 后再填写。
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=mimo-v2.5-pro
ANTHROPIC_BASE_URL=https://token-plan-cn.xiaomimimo.com/anthropic

# RAG 向量数据库配置
EMBEDDING_MODEL=text-embedding-3-small
VECTOR_STORE_TYPE=chroma
VECTOR_STORE_PATH=./data/vectorstore
